# =====================================================
# Vertex Labs Admin Panel — Environment Variables
# Copy to .env.local and fill in your values
# =====================================================

# === DATABASE ===
# Supabase PostgreSQL direct connection (for Prisma)
# Format: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres"

# Supabase connection pooling (for production serverless)
# Format: postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# DATABASE_URL="postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres"

# === AUTH ===
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3001"

# === CLOUDINARY ===
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# === SEED ADMIN ===
SEED_ADMIN_EMAIL="admin@vertexlabs.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# === CORS (public API allowed origins) ===
# Comma-separated list of allowed origins for /api/public/* endpoints
ALLOWED_ORIGINS="http://localhost:5173,https://vertexlabs.com"

# === NOTIFICATIONS (optional) ===
# SMTP for lead email notifications
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@email.com"
# SMTP_PASS="your_app_password"
# NOTIFY_EMAIL="business.vertexlabs@gmail.com"
